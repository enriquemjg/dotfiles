theme = Catppuccin Mocha

# disable bindings that conflict with Zellij
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+up=unbind
keybind = alt+down=unbind
keybind = alt+n=unbind
keybind = alt+f=unbind

keybind = shift+enter=text:\x1b\r

# shaders
custom-shader = shaders/cursor_tail.glsl
custom-shader = shaders/ripple_cursor.glsl

